# Required in all environments except automated tests
AUTH_JWT_SECRET=replace-with-long-random-secret
ADMIN_PASSWORD=change-this-admin-password
ENCRYPTION_SECRET=replace-with-long-random-secret

# Optional
WIKI_STORE_FILE_PATH=./data/wiki-store.json
ADMIN_SESSION_MAX_AGE_SECONDS=43200
AUTH_LOGIN_MAX_FAILURES=8
AUTH_LOGIN_WINDOW_SECONDS=600
AUTH_LOGIN_BLOCK_SECONDS=10800
# Trust x-forwarded-for/x-real-ip only when your reverse proxy is configured to set trusted client IPs.
AUTH_TRUST_PROXY_HEADERS=false
# Optional durable login-rate-limit store path (used for cross-restart persistence).
AUTH_LOGIN_STORE_FILE_PATH=./data/login-rate-limit.json
